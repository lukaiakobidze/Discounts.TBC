## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Visual Studio cache/options directory
.vs/

# Rider (if you ever open it there)
.idea/

# VS Code
.vscode/

# NuGet
*.nupkg
packages/
!packages/build/
*.snupkg

# .NET Core / ASP.NET
appsettings.Development.json
secrets.json

# Entity Framework
Migrations/

# Publish output
publish/
*.pubxml
*.publishproj

# Logs
*.log
Logs/

# OS files
.DS_Store
Thumbs.db