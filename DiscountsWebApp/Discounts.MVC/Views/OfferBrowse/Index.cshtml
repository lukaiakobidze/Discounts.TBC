@model Discounts.Application.Models.PaginatedList<Discounts.Application.DTOs.Offers.OfferDto>
@{
    ViewData["Title"] = "Browse Offers";
    var categories = ViewBag.Categories as IReadOnlyList<Discounts.Application.DTOs.Categories.CategoryDto>;
}

<h2 class="mb-4">Browse Offers</h2>

<form method="get" class="card p-3 mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Search</label>
            <input type="text" name="searchTerm" value="@Context.Request.Query["searchTerm"]" class="form-control" placeholder="Search offers..." />
        </div>
        <div class="col-md-3">
            <label class="form-label">Category</label>
            <select name="categoryId" class="form-select">
                <option value="">All Categories</option>
                @if (categories != null)
                {
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Min Price</label>
            <input type="number" name="minPrice" value="@Context.Request.Query["minPrice"]" class="form-control" step="0.01" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Max Price</label>
            <input type="number" name="maxPrice" value="@Context.Request.Query["maxPrice"]" class="form-control" step="0.01" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-highlight w-100"><i class="fas fa-search me-1"></i>Filter</button>
        </div>
    </div>
</form>

@if (Model.Items.Any())
{
    <div class="row">
        @foreach (var offer in Model.Items)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-secondary">@offer.CategoryName</span>
                            @if (offer.IsSoldOut)
                            {
                                <span class="badge bg-dark">Sold Out</span>
                            }
                            else
                            {
                                <span class="badge badge-discount">-@offer.DiscountPercentage%</span>
                            }
                        </div>
                        <h5 class="card-title">@offer.Name</h5>
                        @if (offer.Description != null)
                        {
                            <p class="card-text text-muted small">@(offer.Description.Length > 100 ? offer.Description[..100] + "..." : offer.Description)</p>
                        }
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="text-decoration-line-through text-muted">$@offer.OriginalPrice.ToString("F2")</span>
                            <span class="h5 text-danger mb-0">$@offer.DiscountedPrice.ToString("F2")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">@offer.RemainingCount left</small>
                            <a asp-action="Details" asp-route-id="@offer.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="?pageNumber=@i&searchTerm=@Context.Request.Query["searchTerm"]&categoryId=@Context.Request.Query["categoryId"]">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-search fa-3x text-muted mb-3"></i>
        <h5>No offers found</h5>
        <p class="text-muted">Try adjusting your filters</p>
    </div>
}
