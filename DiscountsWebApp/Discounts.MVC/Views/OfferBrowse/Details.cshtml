@using Discounts.Domain.Constants
@using Discounts.Application.DTOs.Reviews
@model Discounts.Application.DTOs.Offers.OfferDto
@{
    ViewData["Title"] = Model.Name;
    var reviews = ViewBag.Reviews as IReadOnlyList<ReviewDto> ?? new List<ReviewDto>();
    var avgStars = reviews.Count > 0 ? reviews.Average(r => r.Stars) : 0;
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="position-relative">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" class="card-img-top" alt="@Model.Name" style="height: 180px; object-fit: cover;" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                        <i class="fas fa-tag fa-2x text-muted"></i>
                    </div>
                }
                <span class="position-absolute top-0 end-0 m-2 badge rounded-pill" style="background: rgba(0,0,0,0.55); font-size: 0.85rem;">
                    <i class="fas fa-heart text-danger me-1"></i>@Model.FavouriteCount
                </span>
            </div>
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge badge-category">@Model.CategoryName</span>
                    <span class="badge badge-discount">-@Model.DiscountPercentage%</span>
                </div>
                <h2>@Model.Name</h2>
                <p class="text-muted mt-3">@Model.Description</p>
                <hr />
                <div class="row">
                    <div class="col-6">
                        <small class="text-muted">Valid From</small>
                        <p id="validFrom" data-utc="@(Model.ValidFrom.ToString("yyyy-MM-ddTHH:mm:ss") + "Z")"></p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Valid Until</small>   
                        <p id="validTo" data-utc="@(Model.ValidTo.ToString("yyyy-MM-ddTHH:mm:ss") + "Z")"></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body p-4 text-center">
                <div class="mb-3">
                    <span class="text-decoration-line-through text-muted h5">$@Model.OriginalPrice.ToString("F2")</span>
                </div>
                <div class="h2 text-danger mb-3">$@Model.DiscountedPrice.ToString("F2")</div>
                <p class="text-muted">@Model.RemainingCount coupons remaining</p>

                @if (Model.IsSoldOut)
                {
                    <button class="btn btn-secondary w-100" disabled>Sold Out</button>
                }
                else if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole(Roles.Customer))
                {
                    @if ((bool)ViewBag.IsPurchased)
                    {
                        <button class="btn btn-highlight w-100 mb-2" disabled>
                            <i class="fas fa-check-circle me-1" style="color:var(--highlight);"></i>Already Purchased
                        </button>
                    }
                    else if ((bool)ViewBag.IsReserved)
                    {
                        <button class="btn btn-outline-success w-100 mb-2" disabled>
                            <i class="fas fa-bookmark me-1"></i>Reserved
                        </button>
                        <form asp-controller="Customer" asp-action="Purchase" method="post">
                            <input type="hidden" name="offerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-highlight w-100">
                                <i class="fas fa-shopping-cart me-1"></i>Purchase Coupon
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Customer" asp-action="Reserve" method="post" class="mb-2">
                            <input type="hidden" name="offerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-notice w-100 mb-2">
                                <i class="fas fa-bookmark me-1"></i>Reserve
                            </button>
                        </form>
                        <form asp-controller="Customer" asp-action="Purchase" method="post">
                            <input type="hidden" name="offerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-highlight w-100">
                                <i class="fas fa-shopping-cart me-1"></i>Purchase Coupon
                            </button>
                        </form>
                    }
                    @if ((bool)ViewBag.IsFavourited)
                    {
                        <form asp-controller="Customer" asp-action="RemoveFavourite" method="post" class="mt-2">
                            <input type="hidden" name="offerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-warning w-100">
                                <i class="fas fa-heart-broken me-1"></i>Unfavourite
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Customer" asp-action="AddFavourite" method="post" class="mt-2">
                            <input type="hidden" name="offerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-notice w-100">
                                <i class="fas fa-heart me-1"></i>Favourite
                            </button>
                        </form>
                    }
                }
            </div>
        </div>
    </div>
</div>

@if (reviews.Count > 0)
{
    <div class="mt-4">
        <h4>
            Customer Reviews
            <span class="ms-2 text-warning">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="fas fa-star @(i <= Math.Round(avgStars) ? "text-warning" : "text-muted")"></i>
                }
            </span>
            <small class="text-muted fs-6 ms-1">@avgStars.ToString("F1") / 5 (@reviews.Count review@(reviews.Count == 1 ? "" : "s"))</small>
        </h4>
        <div class="row">
            @foreach (var review in reviews)
            {
                <div class="col-md-6 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-1">
                                <div>
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star @(i <= review.Stars ? "text-warning" : "text-muted")"></i>
                                    }
                                </div>
                                <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                            </div>
                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                <p class="mb-0 mt-1">@review.Comment</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            ['validFrom', 'validTo'].forEach(id => {
                const el = document.getElementById(id);
                const date = new Date(el.dataset.utc);
                el.textContent = date.toLocaleString('en-US', {
                    hour: '2-digit', minute: '2-digit',
                    month: 'short', day: '2-digit', year: 'numeric'
                });
            });
        });
    </script>
}
