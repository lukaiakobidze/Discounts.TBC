@using Discounts.Domain.Constants
@model Discounts.Application.DTOs.Offers.OfferDto
@{
    ViewData["Title"] = Model.Name;
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" class="card-img-top" alt="@Model.Name" style="height: 180px; object-fit: cover;" />
            }
            else
            {
                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                    <i class="fas fa-tag fa-2x text-muted"></i>
                </div>
            }
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge badge-category">@Model.CategoryName</span>
                    <span class="badge badge-discount">-@Model.DiscountPercentage%</span>
                </div>
                <h2>@Model.Name</h2>
                <p class="text-muted mt-3">@Model.Description</p>
                <hr />
                <div class="row">
                    <div class="col-6">
                        <small class="text-muted">Valid From</small>
                        <p id="validFrom" data-utc="@(Model.ValidFrom.ToString("yyyy-MM-ddTHH:mm:ss") + "Z")"></p>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Valid Until</small>   
                        <p id="validTo" data-utc="@(Model.ValidTo.ToString("yyyy-MM-ddTHH:mm:ss") + "Z")"></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body p-4 text-center">
                <div class="mb-3">
                    <span class="text-decoration-line-through text-muted h5">$@Model.OriginalPrice.ToString("F2")</span>
                </div>
                <div class="h2 text-danger mb-3">$@Model.DiscountedPrice.ToString("F2")</div>
                <p class="text-muted">@Model.RemainingCount coupons remaining</p>

                @if (Model.IsSoldOut)
                {
                    <button class="btn btn-secondary w-100" disabled>Sold Out</button>
                }
                else if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole(Roles.Customer))
                {
                    @if ((bool)ViewBag.IsPurchased)
                    {
                        <button class="btn btn-highlight w-100 mb-2" disabled>
                            <i class="fas fa-check-circle me-1"></i>Already Purchased
                        </button>
                    }
                    else if ((bool)ViewBag.IsReserved)
                    {
                        <button class="btn btn-outline-success w-100 mb-2" disabled>
                            <i class="fas fa-bookmark me-1"></i>Reserved
                        </button>
                        <form asp-controller="Customer" asp-action="Purchase" method="post">
                            <input type="hidden" name="offerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-highlight w-100">
                                <i class="fas fa-shopping-cart me-1"></i>Purchase Coupon
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Customer" asp-action="Reserve" method="post" class="mb-2">
                            <input type="hidden" name="offerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-notice w-100 mb-2">
                                <i class="fas fa-bookmark me-1"></i>Reserve
                            </button>
                        </form>
                        <form asp-controller="Customer" asp-action="Purchase" method="post">
                            <input type="hidden" name="offerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-highlight w-100">
                                <i class="fas fa-shopping-cart me-1"></i>Purchase Coupon
                            </button>
                        </form>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            ['validFrom', 'validTo'].forEach(id => {
                const el = document.getElementById(id);
                const date = new Date(el.dataset.utc);
                el.textContent = date.toLocaleString('en-US', {
                    hour: '2-digit', minute: '2-digit',
                    month: 'short', day: '2-digit', year: 'numeric'
                });
            });
        });
    </script>
}
