@model Discounts.Application.Models.PaginatedList<Discounts.Application.DTOs.Offers.OfferDto>
@{
    ViewData["Title"] = "My Favourites";
    ViewData["PageNumber"] = Model.PageNumber;
    ViewData["TotalPages"] = Model.TotalPages;
}
<h2 class="mb-4"><i class="fas fa-heart me-2"></i>My Favourites</h2>
@if (Model != null && Model.Items.Any())
{
    <div class="row">
        @foreach (var offer in Model.Items)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    @if (!string.IsNullOrEmpty(offer.ImagePath))
                    {
                        <img src="@offer.ImagePath" class="card-img-top" alt="@offer.Name" style="height: 160px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center" style="height: 160px;">
                            <i class="fas fa-tag fa-2x text-muted"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge badge-category">@offer.CategoryName</span>
                            <span class="badge badge-discount">-@offer.DiscountPercentage%</span>
                        </div>
                        <h5 class="card-title">@offer.Name</h5>
                        <div class="mt-auto">
                            <div class="mb-2">
                                <span class="text-decoration-line-through text-muted me-2">$@offer.OriginalPrice.ToString("F2")</span>
                                <span class="text-danger fw-bold">$@offer.DiscountedPrice.ToString("F2")</span>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-controller="OfferBrowse" asp-action="Details" asp-route-id="@offer.Id" class="btn btn-sm btn-highlight flex-fill">
                                    <i class="fas fa-eye me-1"></i>View Offer
                                </a>
                                <button type="button" class="btn btn-sm btn-warning"
                                        data-bs-toggle="modal" data-bs-target="#confirmModal"
                                        data-confirm-title="Remove Favourite"
                                        data-confirm-message="Remove '@offer.Name' from your favourites?"
                                        data-form-action="@Url.Action("RemoveFavourite", "Customer")"
                                        data-extra-name="offerId"
                                        data-extra-value="@offer.Id">
                                    <i class="fas fa-heart-broken me-1"></i>Remove
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @await Html.PartialAsync("_Pagination")
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-heart fa-3x text-muted mb-3"></i>
        <h5>No favourites yet</h5>
        <a asp-controller="OfferBrowse" asp-action="Index" class="btn btn-highlight mt-2">Browse Offers</a>
    </div>
}

@await Html.PartialAsync("_ConfirmModal")
