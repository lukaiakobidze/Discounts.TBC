@model Discounts.Application.Models.PaginatedList<Discounts.Application.DTOs.Reservations.ReservationDto>
@{
    ViewData["Title"] = "My Reservations";
    ViewData["PageNumber"] = Model.PageNumber;
    ViewData["TotalPages"] = Model.TotalPages;
}

<h2 class="mb-4"><i class="fas fa-ticket-alt me-2"></i>My Reservations</h2>

@if (Model != null && Model.Items.Any())
{
    <div class="row">
        @foreach (var reservation in Model.Items)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5>@reservation.OfferName</h5>
                        </div>
                        <p class="text-muted small mb-2">Expires: @reservation.ExpirationDate.ToString("HH:mm, MMM dd, yyyy")</p>
                        <div class="d-flex gap-2">
                            <a asp-controller="OfferBrowse" asp-action="Details" asp-route-id="@reservation.OfferId" class="btn btn-sm btn-highlight">
                                <i class="fas fa-eye me-1"></i>View Offer
                            </a>
                            <form asp-action="Purchase" method="post">
                                <input type="hidden" name="offerId" value="@reservation.OfferId" />
                                <button type="submit" class="btn btn-sm btn-highlight">Purchase</button>
                            </form>
                            <button type="button" class="btn btn-sm btn-warning"
                                    data-bs-toggle="modal" data-bs-target="#confirmModal"
                                    data-confirm-title="Cancel Reservation"
                                    data-confirm-message="Cancel your reservation for '@reservation.OfferName'?"
                                    data-form-action="@Url.Action("CancelReservation", "Customer")"
                                    data-extra-name="reservationId"
                                    data-extra-value="@reservation.Id">
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @await Html.PartialAsync("_Pagination")
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-ticket-alt fa-3x text-muted mb-3"></i>
        <h5>No Reservations yet</h5>
        <a asp-controller="OfferBrowse" asp-action="Index" class="btn btn-highlight mt-2">Browse Offers</a>
    </div>
}

@await Html.PartialAsync("_ConfirmModal")
