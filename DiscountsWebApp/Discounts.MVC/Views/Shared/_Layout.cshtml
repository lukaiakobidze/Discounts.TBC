@using Discounts.Domain.Constants
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TBC Discounts</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --primary: #39635a;
            --secondary: #2f614d;
            --accent: #91bfac;
            --highlight: #739c8b;
            --warning: #d18498;
            --darkWarning: #b55b67;
            --notice: #84a5d1;
            --darkNotice: #6f95c7;
        }
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: #f5f6fa;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .navbar {
            background: var(--primary) !important;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: 1px;
        }
        .btn-highlight {
            background: var(--accent);
            color: white;
            border: none;
        }
        .btn-highlight:hover {
            background: var(--highlight);
            color: white;
        }
        .btn-warning {
            background: var(--warning);
            color: white;
            border: none;
        }
        .btn-warning:hover {
            background: var(--darkWarning);
            color: white;
            
        }
        .btn-notice {
            background: var(--notice);
            color: white;
            border: none;
        }
        .btn-notice:hover {
            background: var(--darkNotice);
            color: white;
        }
        .card {
            border: none;
            box-shadow: 0 2px 15px rgba(0,0,0,0.08);
            border-radius: 12px; }
        .badge-discount {
            background: var(--highlight);
            font-size: 0.9rem;
        }
        .badge-category {
            background: var(--notice) !important;
            color: white !important;
        }
        .badge-primary {
            background: var(--highlight) !important;
            color: white !important;
        }
        footer {
            background: var(--primary);
            color: #ccc;
            padding: 2rem 0;
            margin-top: auto;
        }
        .navbar .nav-link {
            color: white !important;
            opacity: 0.85;
        }
        .navbar .nav-link:hover {
            opacity: 1;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-tags me-2"></i>TBC Discounts
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" style="color:white;">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="OfferBrowse" asp-action="Index" style="color:white;">Browse Offers</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole(Roles.Admin))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                    <i class="fas fa-shield-alt me-1"></i>Admin
                                </a>
                            </li>
                        }
                        @if (User.IsInRole(Roles.Merchant))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Merchant" asp-controller="Dashboard" asp-action="Index">
                                    <i class="fas fa-store me-1"></i>Merchant
                                </a>
                            </li>
                        }
                        @if (User.IsInRole(Roles.Customer))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Customer" asp-action="MyCoupons">
                                    <i class="fas fa-ticket-alt me-1"></i>My Coupons
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Customer" asp-action="MyReservations">
                                    <i class="fas fa-ticket-alt me-1"></i>My Reservations
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Customer" asp-action="MyFavourites">
                                    <i class="fas fa-heart me-1"></i>Favourites
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="nav-link btn btn-link">
                                    <i class="fas fa-sign-out-alt me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4" style="flex: 1">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            <p>&copy; @DateTime.Now.Year TBC Discounts - IT Academy Project by Luka Iakobidze</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
