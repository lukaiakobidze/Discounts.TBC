@model Discounts.Application.DTOs.Stats.AdminDashboardDto
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4">Dashboard</h2>
<div class="row">
    <div class="col-md-3 mb-3">
        <a asp-area="" asp-controller="OfferBrowse" asp-action="Index" class="text-decoration-none">
            <div class="card text-center p-3">
                <i class="fas fa-tags fa-2x mb-2" style="color: var(--highlight);"></i>
                <h3>@Model.ActiveOffers</h3>
                <small class="text-muted">Total Active Offers</small>
            </div>
        </a>
    </div>
    <div class="col-md-3 mb-3">
        <a asp-area="Admin" asp-controller="Moderation" asp-action="Index" class="text-decoration-none">
            <div class="card text-center p-3">
                <i class="fas fa-clock fa-2x mb-2" style="color: #84a5d1;"></i>
                <h3>@Model.PendingOffers</h3>
                <small class="text-muted">Total Pending Offers</small>
            </div>
        </a>
    </div>
    <div class="col-md-3 mb-3">
        <a asp-area="Admin" asp-controller="UserManagement" asp-action="Index" class="text-decoration-none">
            <div class="card text-center p-3">
                <i class="fas fa-users fa-2x mb-2" style="color: var(--highlight);"></i>
                <h3>@Model.TotalCustomers</h3>
                <small class="text-muted">Total Customers</small>
            </div>
        </a>
    </div>
    <div class="col-md-3 mb-3">
        <a asp-area="Admin" asp-controller="UserManagement" asp-action="Index" class="text-decoration-none">
            <div class="card text-center p-3">
                <i class="fas fa-users fa-2x mb-2" style="color: var(--highlight);"></i>
                <h3>@Model.TotalMerchants</h3>
                <small class="text-muted">Total Merchants</small>
            </div>
        </a>
    </div>
</div>
