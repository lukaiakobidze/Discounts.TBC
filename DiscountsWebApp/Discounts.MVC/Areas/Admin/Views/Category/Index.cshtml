@model Discounts.Application.Models.PaginatedList<Discounts.Application.DTOs.Categories.CategoryDto>
@{
    ViewData["Title"] = "Categories";
    ViewData["PageNumber"] = Model.PageNumber;
    ViewData["TotalPages"] = Model.TotalPages;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Categories <small class="text-muted fs-6">(@Model.TotalCount total)</small></h2>
    <a asp-action="Create" class="btn btn-highlight"><i class="fas fa-plus me-1"></i>Add Category</a>
</div>

<table class="table table-hover">
    <thead><tr><th>Name</th><th>Description</th><th>Offers</th><th>Actions</th></tr></thead>
    <tbody class="align-middle">
        @foreach (var cat in Model.Items)
        {
            <tr>
                <td>@cat.Name</td>
                <td>@cat.Description</td>
                <td>@cat.OfferCount</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-highlight">Edit</a>
                    <button type="button" class="btn btn-sm btn-warning"
                            data-bs-toggle="modal" data-bs-target="#confirmModal"
                            data-confirm-title="Delete Category"
                            data-confirm-message="Delete '@cat.Name'? This cannot be undone."
                            data-form-action="@Url.Action("Delete", "Category", new { area = "Admin", id = cat.Id })">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@await Html.PartialAsync("_Pagination")
@await Html.PartialAsync("_ConfirmModal")
