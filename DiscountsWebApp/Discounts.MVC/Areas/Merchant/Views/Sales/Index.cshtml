@model IReadOnlyList<Discounts.Application.DTOs.Coupons.CouponDto>
@{
    ViewData["Title"] = "Sales History";
}
<h2 class="mb-4">Sales History</h2>
@if (Model.Any())
{
<table class="table table-hover">
    <thead><tr><th>Coupon Code</th><th>Offer</th><th>Status</th><th>Purchase Date</th></tr></thead>
    <tbody>
    @foreach (var c in Model)
    {
        <tr>
            <td><code>@c.Code</code></td>
            <td>@c.OfferName</td>
                    <td><span class="badge @(c.Status == Discounts.Domain.Enums.CouponStatus.Active ? "badge-primary" : "badge-category")">@c.Status</span></td>
            <td>@c.PurchaseDate.ToString("MMM dd, yyyy")</td>
        </tr>
    }
    </tbody>
</table>
}
else { <p class="text-muted">No sales yet.</p> }
