@model Discounts.MVC.ViewModels.OfferViewModel
@{
    ViewData["Title"] = "Create Offer";
}
<h2 class="mb-4">Create Offer</h2>
<div class="card"><div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row">
        <div class="col-md-8 mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="CategoryId" class="form-label">Category</label>
            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                <option value="">Select Category</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="row">
        <div class="col-md-3 mb-3">
            <label asp-for="OriginalPrice" class="form-label"></label>
            <input asp-for="OriginalPrice" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="OriginalPrice" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="DiscountedPrice" class="form-label"></label>
            <input asp-for="DiscountedPrice" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="DiscountedPrice" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="RemainingCoupons" class="form-label"></label>
            <input asp-for="RemainingCoupons" class="form-control" type="number" />
            <span asp-validation-for="RemainingCoupons" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="ValidFrom" class="form-label"></label>
            <input asp-for="ValidFrom" class="form-control" type="datetime-local" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="ValidTo" class="form-label"></label>
            <input asp-for="ValidTo" class="form-control" type="datetime-local" />
        </div>
    </div>
    <input type="hidden" name="TimezoneOffset" id="timezoneOffset" />

    <div class="mb-3">
        <label asp-for="ImageFile" class="form-label">Image</label>
        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
    </div>


    <button type="submit" class="btn btn-highlight">Create Offer</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
</div></div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('timezoneOffset').value = new Date().getTimezoneOffset();
    </script>
}
